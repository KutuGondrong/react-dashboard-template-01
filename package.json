{
  "name": "react-app",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --mode development",
    "build": "tsc --noEmit && vite build --mode production",
    "preview": "vite preview",
    "prepare": "husky",
    "lint": "eslint src --ext .ts,.tsx && tsc --noEmit",
    "lint:check": "eslint src --ext .ts,.tsx --max-warnings 0 && tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" && eslint src --ext .ts,.tsx --fix",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\""
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "src/**/*.{css,json}": "prettier --write",
    "*.{json,md,yml,yaml}": "prettier --write"
  },
  "volta": {
    "node": "24.18.0",
    "pnpm": "11.17.0"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
