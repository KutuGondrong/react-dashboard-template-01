# Default env — loaded in all modes (make dev & make build)
# Override per mode in .env.development or .env.production when needed

# Base URL for real API (default when unset: /api)
VITE_API_BASE_URL=http://localhost:3000/api

# Tutorial & Components menu (dev default; creator production override in .env.production)
VITE_SHOW_DEV_FEATURES=true

# Scroll-to-top button on all pages (default: true when unset)
VITE_ENABLE_SCROLL_TO_TOP=true
